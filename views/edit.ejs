<%- include("./partials/header.ejs") %>

<main class="page-container">
    <h1 class="page-title">Edit Your Post</h1>

    <div class="glass-card">
        <form action="/update/<%= locals.post.id %>" method="POST">
            <label class="d-block mb-3 fs-3 fw-semibold">Update blog:</label>
            <input type="text" name="title" class="form-input fs-5 mb-4" value="<%= locals.post.title %>" required>
            <textarea name="content" class="form-input" style="min-height: 300px;" required><%= locals.post.content %></textarea>
            
            <div class="text-end mt-4 d-flex justify-content-end gap-3">
                <a href="/post/<%= locals.post.id %>" class="btn btn-secondary px-4 fs-5" style="border: 1px solid var(--border-color); color: var(--text-primary); text-decoration: none; padding: 10px 20px; border-radius: 8px;">Cancel</a>
                <button type="submit" class="btn btn-primary px-5 fs-5">Save Changes</button>
            </div>
        </form>
    </div>
</main>

<%- include("./partials/footer.ejs") %>
