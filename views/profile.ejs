<%- include("./partials/header.ejs") %>

<main class="page-container">
    <div class="glass-card" style="text-align:left;">
        <h1 class="page-title mb-4">Profile</h1>

        <div class="mb-3">
            <div class="text-muted mb-1">Username</div>
            <div style="font-size:1.15rem;"><strong><%= locals.user.username %></strong></div>
        </div>

        <div class="mb-3">
            <div class="text-muted mb-1">Email</div>
            <div style="font-size:1.15rem;"><%= locals.user.email || "—" %></div>
        </div>

        <div class="mb-4">
            <div class="text-muted mb-1">Role</div>
            <div style="font-size:1.15rem; text-transform: capitalize;"><strong><%= locals.user.role %></strong></div>
        </div>

        <div class="d-flex gap-3 justify-content-end" style="border-top: 1px solid var(--border-color); padding-top: 16px;">
            <a href="/dashboard" class="btn btn-outline-light" style="border: 1px solid var(--border-color); color: var(--text-primary);">Back</a>
            <a href="/logout" class="btn btn-primary">Logout</a>
        </div>
    </div>
</main>

<%- include("./partials/footer.ejs") %>
